# ── Baseline configuration — confirmed working ────────────────────────────────
# Eval result: +110% composite vs base on 50 test samples
# Best checkpoint: step=20, loss=0.098

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_PATH=/models/Llama-3.1-Nemotron-Nano-8B-v1
ADAPTER_SYMLINK=nemotron8b-finance-adapter
# After training, point this to your best checkpoint's hf_adapter subfolder:
# ADAPTER_CHECKPOINT=/models/checkpoints/nemotron8b-finance-lora/finance-lora/checkpoints/<step>/hf_adapter

# ── Training (train_1node.py) ─────────────────────────────────────────────────
MAX_STEPS=100
BATCH_SIZE=2
GRAD_ACCUM=4
LORA_RANK=32
LR=5e-5              # 1e-4 causes loss spike after warmup; 5e-5 is stable
MAX_SEQ_LEN=512
WARMUP_STEPS=50
NEMO_IMAGE=nvcr.io/nvidia/nemo:25.09
CHECKPOINT_EVERY=20

# ── Serving ───────────────────────────────────────────────────────────────────
VLLM_IMAGE=vllm/vllm-openai:latest
BASE_HOST=localhost      # ata0
BASE_PORT=8000
FT_HOST=10.0.1.11        # ata1 (use IP, not hostname)
FT_PORT=8001
GPU_MEM_UTIL=0.45        # per container; run base on ata0, FT on ata1
MAX_MODEL_LEN=4096
ENABLE_THINKING=false
MAX_LORA_RANK=32

# ── Eval ─────────────────────────────────────────────────────────────────────
EVAL_MAX_TOKENS=128
EVAL_SAMPLES=50
EVAL_CONCURRENT=true
EVAL_TEMPERATURE=0.1
